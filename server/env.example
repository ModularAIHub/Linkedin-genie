# LinkedIn Genie Environment Variables Example

# LinkedIn API
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=linkedin_genie
DB_USER=postgres
DB_PASSWORD=yourpassword

# Or use connection string (recommended for production):
# DATABASE_URL=postgresql://user:password@host:port/linkedin_genie

# New Platform Database (for teams and user data)
# NEW_PLATFORM_DATABASE_URL=postgresql://user:password@host:port/new_platform
# If not set, will fall back to DATABASE_URL

# App
NODE_ENV=development
PORT=4000

# AI Providers (Platform Mode)
OPENAI_API_KEY=your_openai_api_key
PERPLEXITY_API_KEY=your_perplexity_api_key
GOOGLE_AI_API_KEY=your_google_ai_api_key

# New Platform API Integration
NEW_PLATFORM_API_URL=http://localhost:3000/api

# Scheduler (DB-backed, no Redis required)
LINKEDIN_SCHEDULER_ENABLED=true
LINKEDIN_SCHEDULER_POLL_MS=15000
LINKEDIN_SCHEDULER_BATCH_SIZE=5
LINKEDIN_SCHEDULER_MAX_ATTEMPTS=5
LINKEDIN_SCHEDULER_RETRY_BASE_MS=60000
LINKEDIN_SCHEDULER_RETRY_MAX_MS=900000
LINKEDIN_RUN_SCHEDULER_IN_API=false
# Shared bearer secret for /api/cron/* endpoints (Vercel/QStash)
CRON_SECRET=your_long_random_cron_secret
# Daily content-plan cron defaults
LINKEDIN_DAILY_CONTENT_CRON_ENABLED=true
LINKEDIN_DAILY_CONTENT_QUEUE_TARGET=2
LINKEDIN_DAILY_CONTENT_NOTIFY=true
LINKEDIN_CONTENT_PLAN_CRON_TIMEZONE=UTC

# Cross-post integration (LinkedIn -> X / Threads)
INTERNAL_API_KEY=your_shared_internal_api_key
TWEET_GENIE_URL=http://localhost:3002
SOCIAL_GENIE_URL=http://localhost:3006
X_CROSSPOST_TIMEOUT_MS=10000
THREADS_CROSSPOST_TIMEOUT_MS=10000

# Email notifications (Resend)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@suitegenie.in
RESEND_FROM_NAME=SuiteGenie
# Set to false to disable email reminders
LINKEDIN_EMAIL_NOTIFICATIONS_ENABLED=true
# Notification worker cadence (milliseconds)
LINKEDIN_NOTIFICATION_POLL_MS=900000
# Max users evaluated per tick
LINKEDIN_NOTIFICATION_MAX_USERS_PER_TICK=25
# Sample comments included in pending-reply email
LINKEDIN_NOTIFICATION_COMMENT_SAMPLE_LIMIT=3
# "No post published" lookback window
LINKEDIN_NOTIFICATION_READY_LOOKBACK_HOURS=24
# Auto-generate reply drafts from new unreplied comments (approval still required)
LINKEDIN_AUTO_REPLY_DRAFTS_ENABLED=true
LINKEDIN_AUTO_REPLY_DRAFTS_PER_USER=2
LINKEDIN_AUTO_REPLY_USER_SCAN_LIMIT=20

LOG_LEVEL=info
